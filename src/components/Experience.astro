---
const experiences = [
  {
    id: 1,
    title: "Senior Product Designer",
    company: "Tech Company",
    logo: "/companies/techcompany.png",
    period: "2022 - Present",
    location: "Lisbon, Portugal",
    description: "Led design system implementation and user experience improvements across multiple products.",
    skills: ["Figma", "Design Systems", "User Research"]
  },
  {
    id: 2,
    title: "Product Designer",
    company: "Design Studio",
    logo: "/companies/designstudio.png",
    period: "2020 - 2022",
    location: "Porto, Portugal",  
    description: "Designed mobile and web applications with focus on user-centered design principles.",
    skills: ["UI/UX", "Prototyping", "User Testing"]
  },
  {
    id: 3,
    title: "Junior Designer",
    company: "Startup Inc",
    logo: "/companies/startup.png",
    period: "2018 - 2020",
    location: "Remote",
    description: "Created visual designs and interactive prototypes for early-stage products.",
    skills: ["Visual Design", "Wireframing", "Branding"]
  }
];
---

<section class="py-16 px-8 bg-white">
  <div class="max-w-8xl mx-auto">
    <h2 class="text-5xl font-bold text-center mb-16 text-gray-900">Professional Experience</h2>
    
    <div class="relative max-w-7xl mx-auto">
      <div class="absolute left-1/2 top-0 bottom-0 w-1 bg-gray-200 -translate-x-1/2"></div>
      
      <div class="space-y-0">
        {experiences.map((exp, index) => (
          <div class="relative py-8">
            <div class="absolute left-1/2 top-8 w-4 h-4 bg-gray-900 rounded-full -translate-x-1/2 z-10"></div>
            
            <div class={`flex ${index % 2 === 0 ? 'flex-row' : 'flex-row-reverse'}`}>
              <div class="w-1/2"></div>
              
              <div class="w-1/2 px-6">
                <div class="bg-gray-50 p-6 rounded-lg hover:shadow-lg transition-shadow duration-200">
                  <div class="text-sm text-gray-500 font-medium mb-2">{exp.period}</div>

                  {/* Logo + title + company row */}
                  <div class="flex items-center gap-3 mb-4">
                    <div class="flex-shrink-0 w-10 h-10 bg-white rounded-lg border border-gray-100 shadow-sm flex items-center justify-center overflow-hidden">
                      <img src={exp.logo} alt={exp.company} class="w-7 h-7 object-contain" />
                    </div>
                    <div>
                      <h3 class="text-2xl font-bold text-gray-900">{exp.title}</h3>
                      <div class="text-sm text-gray-600">{exp.company} • {exp.location}</div>
                    </div>
                  </div>

                  {/* Everything else unchanged */}
                  <p class="text-gray-600 text-sm leading-relaxed mb-4">{exp.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {exp.skills.map(skill => (
                      <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-medium">
                        {skill}
                      </span>
                    ))}
                  </div>

                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>