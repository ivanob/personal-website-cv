---
const underDevelopment = false; // set to false to remove the overlay

const skills = [
  {
    category: "Backend",
    icon: "⚙️",
    items: [
      { tech: "Typescript / Javascript / Node", description: "Type-safe JavaScript", explanation: "Expert" },
      { tech: "Rust", description: "Systems programming language", explanation: "Intermediate level (Learning)" },
      { tech: "Java", description: "Object-oriented programming language", explanation: "A bit rusty" },
      { tech: "NestJS", description: "Progressive Node.js framework", explanation: "Professional experience" },
    ]
  },
  {
    category: "Cloud & Platform",
    icon: "☁️",
    items: [
      { tech: "AWS services", description: "Cloud computing services", explanation: "Expert" },
      { tech: "Serverless", description: "Serverless computing", explanation: "Expert" },
      { tech: "ECS", description: "Elastic Container Service", explanation: "Advanced level" },
      { tech: "Docker", description: "Containerisation", explanation: "Advanced level" },
      { tech: "Kubernetes", description: "Container orchestration", explanation: "Intermediate level (Learning)" },
      { tech: "Terraform", description: "Infrastructure as code", explanation: "Expert" },
    ]
  },
  {
    category: "Frontend",
    icon: "🎨",
    items: [
      { tech: "React", description: "Component-based UI development", explanation: "Professional experience" },
      { tech: "Next.js", description: "React framework for server-side rendering", explanation: "Professional experience" },
      { tech: "Astro", description: "Static site generation", explanation: "Basic level" },
      { tech: "Tailwind CSS", description: "Utility-first styling", explanation: "Basic level" },
    ]
  },
  {
    category: "Databases",
    icon: "🗄️",
    items: [
      { tech: "PostgreSQL", description: "Relational database", explanation: "Advanced level" },
      { tech: "DynamoDB / MongoDB", description: "NoSQL database", explanation: "Expert" },
      { tech: "Redis", description: "In-memory data structure store", explanation: "" },
      { tech: "Kafka", description: "Distributed event streaming platform", explanation: "Used as AWS Kinesis" },
    ]
  },
  {
    category: "Services & Tools",
    icon: "🚀",
    items: [
      { tech: "GitHub Actions", description: "CI/CD pipelines", explanation: "" },
      { tech: "Cloudflare CDN", description: "Web performance and security", explanation: "" },
      { tech: "Git", description: "Version control", explanation: "" },
    ]
  },
  {
    category: "Methodologies",
    icon: "📐",
    items: [
      { tech: "DDD", description: "Domain-Driven Design", explanation: "Expert" },
      { tech: "Event-driven Architecture", description: "Design pattern for building scalable systems", explanation: "Expert" },
      { tech: "Microservices", description: "Architectural style for building applications", explanation: "Expert" },
      { tech: "Clean architectures", description: "Software design philosophy", explanation: "+10 years experience" },
      { tech: "Agile (Scrum & Kanban)", description: "Agile methodologies", explanation: "+10 years experience" },
    ]
  }
];
---

<section class="py-16 px-8 bg-white" id="skills">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-5xl font-bold text-center mb-12 text-gray-900">Skills</h2>

    <div class="relative">
      {underDevelopment && (
        <div class="absolute inset-0 z-20 flex items-center justify-center rounded-xl backdrop-blur-sm bg-white/60">
          <span class="text-black-400 text-sm font-medium tracking-widest uppercase">Under development</span>
        </div>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {skills.map((group) => (
        <div class="bg-gray-50 rounded-2xl p-8 hover:shadow-md transition-shadow duration-300">
          
          {/* Category Header */}
          <div class="flex items-center gap-3 mb-6">
            <span class="text-3xl">{group.icon}</span>
            <h3 class="text-2xl font-bold text-gray-900">{group.category}</h3>
          </div>

          {/* Skills List */}
          <ul class="space-y-4">
            {group.items.map((item) => (
              <li class="flex items-center gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0" />
                <span class="inline-flex items-center gap-2">
                  <span class="bg-blue-900 text-white text-sm font-medium px-3 py-1 rounded-full cursor-help" title={item.description}>
                    {item.tech}
                  </span>
                  {item.explanation && <span class="text-gray-600 text-sm">{item.explanation}</span>}
                </span>
              </li>
            ))}
          </ul>

        </div>
      ))}
      </div>
    </div>
  </div>
</section>