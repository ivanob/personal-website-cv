          </svg>
        </a>
        
        <a href="https://github.com/yourprofile" target="_blank" rel="noopener noreferrer" class="w-12 h-12 border-2 border-gray-300 rounded-full bg-white flex items-center justify-center hover:border-gray-900 hover:bg-gray-50 transition-all duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-gray-900">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

{/* Sticky Navigation Header */}
<header id="stickyNav" class="fixed top-0 left-0 right-0 bg-white shadow-lg transition-all duration-300 z-50" style="transform: translateY(-100%)">
  <div class="max-w-6xl mx-auto px-8 py-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <h2 class="text-lg font-bold text-gray-900">Ivan Obeso</h2>
      <span class="text-gray-600 text-sm">Senior Product Designer</span>
    </div>
    
    <nav class="flex items-center gap-8">
      <a href="#experience" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 text-sm">
        Experience
      </a>
      <a href="#projects" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 text-sm">
        Projects
      </a>
      <a href="#skills" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 text-sm">
        Skills
      </a>
      <a href="#interests" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 text-sm">
        Interests
      </a>
      
      <div class="flex items-center gap-2 ml-4 pl-4 border-l border-gray-200">
        <a href="https://linkedin.com/in/yourprofile" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center hover:text-blue-600 transition-colors duration-200">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
        </a>
        
        <a href="https://github.com/yourprofile" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center hover:text-gray-900 transition-colors duration-200">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const stickyNav = document.getElementById('stickyNav');
  const hero = document.getElementById('hero');
  const heroTitle = document.getElementById('heroTitle');
  const heroSubtitle = document.getElementById('heroSubtitle');
  const heroButtons = document.getElementById('heroButtons');
  
  window.addEventListener('scroll', () => {
    const heroHeight = hero.offsetHeight;
    const scrollPosition = window.scrollY;
    const scrollPercent = Math.min(scrollPosition / (heroHeight * 0.5), 1);
    
    // Move sticky nav down as you scroll
    const translateY = scrollPercent * 100;
    stickyNav.style.transform = `translateY(-${100 - translateY}%)`;
    
    // Fade out hero title and subtitle
    heroTitle.style.opacity = Math.max(1 - scrollPercent, 0);
    heroSubtitle.style.opacity = Math.max(1 - scrollPercent, 0);
    heroTitle.style.transform = `translateY(-${scrollPercent * 20}px)`;
    heroSubtitle.style.transform = `translateY(-${scrollPercent * 20}px)`;
    
    // Fade out buttons
    heroButtons.style.opacity = Math.max(1 - scrollPercent, 0);
    heroButtons.style.transform = `translateY(${scrollPercent * 10}px)`;
  });
  
  // Smooth scroll to sections
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>