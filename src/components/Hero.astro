---

<section class="py-16 px-8 bg-gray-50" id="hero">
  <div class="max-w-6xl mx-auto flex items-center gap-12 flex-col md:flex-row text-center md:text-left">
    <div class="flex-shrink-0">
      <img src="/avatar.jpg" alt="Ivan Obeso" class="w-36 h-36 rounded-full object-cover" />
    </div>
    
    <div id="heroContent" class="flex-1 transition-all duration-300">
      <h1 id="heroTitle" class="text-5xl md:text-6xl font-bold mb-2 text-gray-900 transition-all duration-300">
        Ivan Obeso
      </h1>
      <p id="heroSubtitle" class="text-xl text-gray-600 mb-8 transition-all duration-300">
        Senior Product Designer, Lisbon - Portugal
      </p>
      
      <div class="hidden md:flex items-center gap-8">
        {/* Navigation Links */}
        <nav class="flex items-center gap-6">
          <a href="#experience" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200">
            Experience
          </a>
          <a href="#projects" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200">
            Projects
          </a>
          <a href="#skills" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200">
            Skills
          </a>
          <a href="#interests" class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200">
            Interests
          </a>
        </nav>
      </div>
      
      <div id="heroButtons" class="flex items-center gap-4 justify-center md:justify-start mt-8 md:mt-0 transition-all duration-300">
        <button class="bg-gray-900 text-white px-8 py-3 rounded-full text-base font-medium hover:bg-gray-700 transition-colors duration-200">
          Download CV
        </button>
        
        <a href="https://linkedin.com/in/yourprofile" target="_blank" rel="noopener noreferrer" class="w-12 h-12 border-2 border-gray-300 rounded-full bg-white flex items-center justify-center hover:border-gray-900 hover:bg-gray-50 transition-all duration-200">
