---
const hero = {
  name: "Ivan Obeso",
  title: "Senior Backend Engineer",
  location: "🇵🇹 Lisbon, Portugal",
  status: "🇪🇺 EU Resident · No visa needed",
  avatar: "/avatar.png",
  quote: "I am a senior Software Engineer with a Bachelor’s degree and an MSc in Computer Science, "
  + "and 15+ years of professional experience across the full software development lifecycle, "
  + "with a strong focus on backend engineering. My background is centered on designing and "
  + "building cloud-based distributed systems, from API definition to architecture design and "
  + "implementation, with extensive experience in system optimization, scalability, and reliability.",

  description: "In my most recent role, I led a team of 6 developers from the very early stages through the "
  + "successful delivery of an MVP and its launch into production. My responsibilities included "
  + "defining and communicating the architecture, guiding development, making technical "
  + "decisions, and fostering strong team engagement. I have successfully mentored junior "
  + "developers, enabling them to ramp up quickly and contribute effectively. I attribute my "
  + "effectiveness as a team lead to clear communication—both within the engineering team and "
  + "with stakeholders.",
  blog: "https://ivanobeso.dev/blog",
  linkedin: "https://www.linkedin.com/in/ivanobeso/",
  github: "https://github.com/ivanob",
  email: "ivan.obeso.dev@gmail.com",
  nav: [
    { label: "Experience", href: "#experience" },
    { label: "Projects", href: "#projects" },
    { label: "Skills", href: "#skills" },
    { label: "Education", href: "#education" },
  ]
}
---

<section class="py-12 px-8 bg-gray-50" id="hero">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    
    {/* LEFT - Identity */}
    <div id="heroLeft" class="flex flex-col gap-6 items-center">

      {/* Avatar */}
      <div class="flex items-center gap-5">
        <img src={hero.avatar} alt={hero.name} class="w-20 h-20 rounded-full object-cover ring-2 ring-gray-900 ring-offset-2 ring-offset-gray-50" />
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{hero.name}</h1>
          <p class="text-gray-500 text-sm mt-1">{hero.title} · {hero.location}</p>
          <p class="text-gray-400 text-xs mt-0.5">{hero.status}</p>
        </div>
      </div>

      {/* Nav Links */}
      <nav class="hidden md:flex flex-wrap gap-3">
        {hero.nav.map((item, index) => (
          <>
            <a href={item.href} class="text-sm text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200">
              {item.label}
            </a>
            {index < hero.nav.length - 1 && <span class="text-gray-300">·</span>}
          </>
        ))}
      </nav>

      {/* Social Links */}
      <div id="heroButtons" class="flex items-center gap-3">
        <a href={hero.linkedin} target="_blank" rel="noopener noreferrer" class="w-9 h-9 border border-gray-200 rounded-full bg-white flex items-center justify-center hover:border-gray-900 transition-all duration-200">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-gray-700">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
        </a>
        <a href={hero.github} target="_blank" rel="noopener noreferrer" class="w-9 h-9 border border-gray-200 rounded-full bg-white flex items-center justify-center hover:border-gray-900 transition-all duration-200">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-gray-700">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a 
          href={`mailto:${hero.email}`}
          class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-900 px-5 py-2 rounded-full text-sm font-medium hover:border-gray-900 transition-all duration-200"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,12 2,6"/>
          </svg>
          Say hello
        </a>
        <button class="bg-gray-900 text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors duration-200">
          Download CV
        </button>
      </div>
    </div>

    {/* RIGHT - About me */}
    <div class="border-l border-gray-200 pl-16 pr-12">
      <p class="text-gray-400 text-xs font-semibold uppercase tracking-widest mb-4">About me</p>
      <blockquote class="font-serif text-gray-700 text-xl leading-relaxed italic">
        "{hero.quote}"
      </blockquote>
      <p class="font-serif text-gray-600 text-lg leading-relaxed mt-4">
        {hero.description}
      </p>
      <a 
        href={hero.blog}
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-8 text-gray-900 font-medium border-b-2 border-gray-900 pb-0.5 hover:border-gray-400 hover:text-gray-400 transition-all duration-200"
      >
        Read my blog
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

{/* Sticky Navigation Header */}
<header id="stickyNav" class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md shadow-sm transition-all duration-300 z-50" style="transform: translateY(-100%);">
  <div class="max-w-6xl mx-auto px-8 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <img src={hero.avatar} alt={hero.name} class="w-8 h-8 rounded-full object-cover ring-2 ring-gray-900 ring-offset-2 ring-offset-white" />
      <h2 class="text-sm font-bold text-gray-900">{hero.name}</h2>
      <span class="text-gray-400 text-xs">{hero.title}</span>
    </div>
    
    <nav class="hidden lg:flex items-center gap-8">
      {hero.nav.map((item) => (
        <a href={item.href} class="text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 text-sm">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={hero.linkedin} target="_blank" rel="noopener noreferrer" class="w-7 h-7 flex items-center justify-center text-gray-600 hover:text-blue-600 transition-colors duration-200">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
        </svg>
      </a>
      <a href={hero.github} target="_blank" rel="noopener noreferrer" class="w-7 h-7 flex items-center justify-center text-gray-600 hover:text-gray-900 transition-colors duration-200">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

{/* Floating Buttons */}
<div id="fab" class="fixed bottom-8 right-8 z-50 flex flex-col items-end gap-3 opacity-0 pointer-events-none transition-all duration-300">
  
  <a
    href={`mailto:${hero.email}`}
    class="flex items-center gap-3 bg-white border border-gray-200 text-gray-900 pl-4 pr-5 py-2.5 rounded-full text-sm font-medium shadow-lg hover:shadow-xl hover:border-gray-900 transition-all duration-200"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,12 2,6"/>
    </svg>
    Say hello
  </a>

  <a
    href="/cv.pdf"
    download
    class="flex items-center gap-3 bg-gray-900 text-white pl-4 pr-5 py-2.5 rounded-full text-sm font-medium shadow-lg hover:shadow-xl hover:bg-gray-700 transition-all duration-200"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/>
      <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Download CV
  </a>

</div>

<script>
  const stickyNav = document.getElementById('stickyNav');
  const hero = document.getElementById('hero');
  const heroLeft = document.getElementById('heroLeft');
  const fab = document.getElementById('fab');

  window.addEventListener('scroll', () => {
    const heroHeight = hero.offsetHeight;
    const scrollPercent = Math.min(window.scrollY / (heroHeight * 0.4), 1);

    // Left side blurs and fades out
    const blur = scrollPercent * 8;
    const opacity = Math.max(1 - scrollPercent * 1.5, 0);
    const scale = 1 - scrollPercent * 0.05;
    heroLeft.style.filter = `blur(${blur}px)`;
    heroLeft.style.opacity = opacity.toString();
    heroLeft.style.transform = `scale(${scale})`;

    // Sticky nav slides in from top
    stickyNav.style.transform = `translateY(calc(-100% + ${scrollPercent * 100}%))`;
    stickyNav.style.opacity = scrollPercent.toString();

    // FAB appears
    if (scrollPercent >= 1) {
      fab.style.opacity = '1';
      fab.style.pointerEvents = 'auto';
    } else {
      fab.style.opacity = '0';
      fab.style.pointerEvents = 'none';
    }
  });

  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>