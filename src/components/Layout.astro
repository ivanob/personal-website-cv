---
// No props needed for now, but you can add them later for reusability
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-avatar">
      <img src="/avatar.jpg" alt="Ivan Obeso" class="avatar-image" />
    </div>
    
    <div class="hero-content">
      <h1 class="hero-name">Ivan Obeso</h1>
      <p class="hero-title">Senior Product Designer, Lisbon - Portugal</p>
      
      <div class="hero-actions">
        <button class="download-cv">Download CV</button>
        <button class="contact-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </button>
        <button class="theme-toggle">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <circle cx="12" cy="12" r="5"></circle>
            <path d="m12 1v2m12 11h-2M12 21v2M4.2 4.2l1.4 1.4m12.8 0 1.4-1.4M4.2 19.8l1.4-1.4m12.8 0 1.4 1.4"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 2rem;
    background: #f8f9fa;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  
  .hero-avatar {
    flex-shrink: 0;
  }
  
  .avatar-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .hero-content {
    flex: 1;
  }
  
  .hero-name {
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
    color: #1a1a1a;
  }
  
  .hero-title {
    font-size: 1.25rem;
    color: #666;
    margin: 0.5rem 0 2rem 0;
  }
  
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .download-cv {
    background: #1a1a1a;
    color: white;
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 2rem;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  
  .download-cv:hover {
    background: #333;
  }
  
  .contact-btn,
  .theme-toggle {
    width: 48px;
    height: 48px;
    border: 2px solid #e0e0e0;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .contact-btn:hover,
  .theme-toggle:hover {
    border-color: #333;
    background: #f5f5f5;
  }
  
  @media (max-width: 768px) {
    .hero-container {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }
    
    .hero-name {
      font-size: 2.5rem;
    }
  }
</style>---
