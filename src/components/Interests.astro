---
const interests = [
  {
    emoji: "♟️",
    title: "Chess",
    url: "https://www.chess.com/member/cachopivoro",
    description: "Challenge me!"
  },
  {
    emoji: "🎶",
    title: "Music",
    url: "https://open.spotify.com/user/cachopivoro?si=f3509d919e254f50",
    description: "Spotify listener"
  },
  {
    emoji: "🏋️",
    title: "Exercise",
    url: "https://www.youtube.com/watch?v=kwqnYtmUuNo",
    description: "Irons & Gainz"
  }
]
---

<section class="py-16 px-8 bg-gray-50" id="interests">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-5xl font-bold mb-12 text-gray-900">Interests</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {interests.map((interest) => (
        <div class="flex flex-col gap-3 p-8 bg-white rounded-2xl hover:shadow-md transition-shadow duration-300">
          <span class="text-4xl">{interest.emoji}</span>
          <h3 class="text-lg font-bold text-gray-900">{interest.title}</h3>
        
          {interest.url && (
            <a href={interest.url} target="_blank" rel="noopener noreferrer" class="text-blue-600 underline hover:text-blue-800 transition-colors duration-200 text-sm">{interest.description}</a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>